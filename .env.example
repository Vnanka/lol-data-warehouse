# Copy this file to .env and fill in your own values.
# .env is git-ignored; .env.example is committed as a template.

# Riot API key — get a development key at https://developer.riotgames.com/
# Dev keys expire every 24h. Regenerate and paste back in.
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Your in-game identity. RIOT_GAME_NAME is the name before the #,
# RIOT_TAG_LINE is what comes after.
RIOT_GAME_NAME=YourGameName
RIOT_TAG_LINE=EUW

# Your PUUID — run src/extract/fetch_puuid.py once to discover it,
# then paste it here so subsequent pipeline runs don't have to look it up.
PUUID=
