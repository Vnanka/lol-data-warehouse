# =========================
# Secrets / environment
# =========================
.env
.env.*
!.env.example

# Why:
# - .env contains API keys (RIOT_API_KEY) — must NEVER be committed
# - .env.example IS committed as a template


# =========================
# Local data & databases
# =========================
data/
*.sqlite
*.duckdb
*.duckdb.wal

# Why:
# - raw API responses, intermediate CSVs, personal data
# - the warehouse file itself is reproducible from scratch


# =========================
# dbt artefacts
# =========================
dbt/target/
dbt/dbt_packages/
dbt/logs/

# Why:
# - target/ is regenerated on every `dbt build`
# - dbt_packages/ is installed by `dbt deps`
# - logs/ are local-only


# =========================
# Python cache / compiled
# =========================
__pycache__/
*.pyc
*.pyo


# =========================
# Virtual environments
# =========================
.venv/
venv/


# =========================
# VS Code
# =========================
.vscode/


# =========================
# OS junk
# =========================
.DS_Store
Thumbs.db
